# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.pytest_cache/

# Virtual envs
.env
.venv/
venv/
env/

# IDE / OS
.vscode/
.idea/
.DS_Store
*.swp

# Streamlit secrets — NEVER commit
.streamlit/secrets.toml

# Cached data and runtime artifacts
data/raw/*.csv
data/processed/*.csv
logs/*.csv
results/*.csv
results/paper_state.json

# But keep folder structure
!data/raw/.gitkeep
!data/processed/.gitkeep
!logs/.gitkeep
!results/.gitkeep
